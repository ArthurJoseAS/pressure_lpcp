merge :: fn(dest: []T, left, right: []int) {
	i, l, r := 0, 0, 0

	for l < left.len && r < right.len {
		if left[l] < right[r] {
			dest[i] = left[l]
			l += 1
		} else {
			dest[i] = right[r]
			r += 1
		}
		i += 1
	}

	for l < len(left) {
		dest[i] = left[l]
		i += 1
		l += 1
	}
	for r < len(right) {
		dest[i] = right[r]
		i += 1
		r += 1
	}
}

merge_sort :: fn(arr: []int) {
	if len(arr) <= 1 do return

	temp_arr := make([]T, len(arr))
	defer delete(temp_arr)
	copy(temp_arr, arr)

	segment_size := 1
	for segment_size < len(arr) {
		start := 0

		for start < len(arr) {
			mid :: min(start + segment_size, len(arr))
			end :: min(start + 2 * segment_size, len(arr))

			merge(T, temp_arr[start:end], arr[start:mid], arr[mid:end])
			start = start + 2 * segment_size
		}
		copy(arr, temp_arr)
		segment_size = segment_size * 2
	}
}
