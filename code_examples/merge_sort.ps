fn mergeSort(type : T , mut arr: [] T) {
  if (arr.len <= 1) {
    return;
  }

  let temp_arr: mut []T = arr.copy();
  let segment_size: mut i32 = 1;
  while (segment_size < arr.len) {
    let start: mut i32 = 0;
    while (start < arr.len) {
      let mid = min(start + segment_size, arr.len);
      let end = min(start + 2 * segment_size, arr.len);
      
      merge(T, temp_arr[start..end], arr[start..mid], arr[mid..end]);
      start = start + 2 * segment_size;
    }
    memcpy(arr, temp_arr);
    segment_size = segment_size * 2;
  }
}

fn merge(type : T, mut arr: [] T, left_arr: []T, right_arr: []T) {
  let i: mut i32 = 0; let l: mut i32 = 0; let r: mut i32 = 0;
  while (l < left_arr.len and r < right_arr.len) {
    if (left_arr[l] < right_arr[r]) {
      arr[i] = left_arr[l];
      l = l + 1;
    } else {
      arr[i] = right_arr[r];
      r = r + 1;
    }
    i = i + 1;
  }
  while (l < left_arr.len) {
    arr[i] = left_arr[l];
    i = i + 1;
  }
  while (r < right_arr.len) {
    arr[i] = right_arr[r];
    i = i + 1;
    r = r + 1;
  }
}

fn main() {
  let arr: mut [] u32 = [3, 3, 4, 6, 7, 8];
  mergeSort(u32, arr);
}
